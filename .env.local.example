# Copy to .env.local and fill in values
# Get these from Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only (never exposed to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe (Phase 7 - optional)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Email notifications (Resend — sign up free at https://resend.com)
# Without these set, the app still works but no emails go out (logged only).
# RESEND_API_KEY=re_your_key_here
# EMAIL_FROM=Printvolution <orders@printvolution.sg>
# ADMIN_NOTIFICATION_EMAIL=admin@printvolution.sg

# Cloudflare Turnstile captcha (free, unlimited).
# Create a site at https://dash.cloudflare.com/?to=/:account/turnstile
# then paste the site key + secret here. Without these set, the captcha
# widget renders with Cloudflare's always-pass test key (bots walk in) —
# production MUST set real keys.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxxxx
# TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sentry error tracking — only fires in Vercel preview + production.
# DSN is from https://sentry.io → Project Settings → Client Keys (DSN)
# Without these the SDK no-ops; the app still works.
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxx@oXXXX.ingest.sentry.io/YYYY
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxx     # build-time, for source map upload
# SENTRY_ORG=printvolution
# SENTRY_PROJECT=printvolution-web
