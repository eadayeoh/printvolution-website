# Copy to .env.local and fill in values
# Get these from Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only (never exposed to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe (Phase 7 - optional)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Email notifications (Resend — sign up free at https://resend.com)
# Without these set, the app still works but no emails go out (logged only).
# RESEND_API_KEY=re_your_key_here
# EMAIL_FROM=Printvolution <orders@printvolution.sg>
# ADMIN_NOTIFICATION_EMAIL=admin@printvolution.sg
