# Copy to .env.local and fill in values for local dev.
# Production values live in Vercel project settings.

# ────────────────────────────────────────────────────────────
# Supabase
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional — direct Postgres URL (used by some scripts/migrations)
SUPABASE_DB_URL=
DATABASE_URL=

# ────────────────────────────────────────────────────────────
# Site
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://printvolution.sg

# ────────────────────────────────────────────────────────────
# OpenAI (gift product generation)
# ────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ────────────────────────────────────────────────────────────
# Email (Resend)
# ────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=
ADMIN_NOTIFICATION_EMAIL=

# ────────────────────────────────────────────────────────────
# HitPay (payments)
# ────────────────────────────────────────────────────────────
HITPAY_ENABLED=
HITPAY_MODE=
HITPAY_API_KEY=
HITPAY_SALT=
HITPAY_WEBHOOK_URL=

# ────────────────────────────────────────────────────────────
# Cloudflare Turnstile (captcha)
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ────────────────────────────────────────────────────────────
# Cron / scheduled jobs
# ────────────────────────────────────────────────────────────
CRON_SECRET=

# ────────────────────────────────────────────────────────────
# Sentry error tracking
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ────────────────────────────────────────────────────────────
# pvpricelist source DB (separate Supabase project, read-only anon key)
# ────────────────────────────────────────────────────────────
PVPRICELIST_URL=
PVPRICELIST_ANON_KEY=
PVPRICELIST_WEBHOOK_SECRET=
